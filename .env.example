# Copy to .env.local and fill in. For local dev, run `supabase start` and use
# `supabase status -o env` to read the local URL + keys.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local: http://127.0.0.1:54321  ·  Hosted: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Service role bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Stripe (scaffolded; gate behind the flag) ─────────────────────────────────
# Set STRIPE_ENABLED=true AND add a secret key to turn payments on. No rebuild.
STRIPE_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Without a key, transactional email no-ops and logs to the console.
RESEND_API_KEY=""
EMAIL_FROM="CARRY <onboarding@resend.dev>"

# ── SMS (Twilio, optional) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Google Calendar (optional two-way sync; gate behind the flag) ─────────────
# Bookings always email a native .ics invite (zero cost). This OAuth sync is an
# Google Calendar two-way sync was removed (V3-P4.6) — native .ics invites
# are the calendar path and need no keys.
# turn it on; with the flag off the app runs fully without these. Free Google
# Calendar API — no recurring cost.

# Cron protection (Vercel Cron sends this as a Bearer token)
CRON_SECRET=""
